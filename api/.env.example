# Server
PORT=3000

# Optional database
# MONGO_URI=mongodb://localhost:27017/arvindrai

# PhonePe Production Checkout
# Backend fetches temporary checkout token from api/index.js only.
PAYMENT_CLIENT_ID=
PAYMENT_CLIENT_SECRET=
PAYMENT_CLIENT_VERSION=1
# Optional checkout expiry window in seconds (300-3600)
# PAYMENT_EXPIRE_AFTER_SECONDS=1200

# Production redirect/callback domain is fixed to:
# https://arvindrai.in

# Prokerala OAuth (Astrology + Numerology APIs)
CLIENT_ID=
CLIENT_SECRET=

# Optional Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional SMTP for contact notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
